# Local development defaults. Copy to .env and replace placeholders as needed.
# Do not commit real secrets.

POSTGRES_DB=doc_intel
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_URL=postgresql://admin:change-me@postgres:5432/doc_intel

REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=documents
MINIO_SECURE=false

PINECONE_API_KEY=replace-with-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=doc-intelligence
SEC_USER_AGENT=Your Name your.email@example.com

GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL_NAME=gemini-2.5-flash
MISTRAL_API_URL=http://mistral:8000
LLM_ORCHESTRATOR_URL=http://llm-orchestrator:8002
INGESTION_SERVICE_URL=http://ingestion:8001
DOCUMENTS_AUTHORITY_URL=

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://mlflow
MLFLOW_BACKEND_STORE_URI=postgresql://admin:change-me@postgres:5432/doc_intel

PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_PASSWORD=change-me

REQUIRE_SECURE_CONFIG=false
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=dev_secret_key_at_least_32_characters_long
API_KEY_PEPPER=dev_pepper_at_least_32_characters_long

OCR_LANGUAGES=en
OCR_DPI=200
MAX_FILE_SIZE_MB=100
ENABLE_WORKERS=false
